# =========================
# 🚀 APP CONFIG
# =========================
NODE_ENV=development
PORT=5000

# Base API URL (used for callbacks, mobile apps, etc.)
BASE_URL=http://localhost:5000

# =========================
# 🔐 AUTH CONFIG
# =========================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# =========================
# 🗄️ DATABASE
# =========================
MONGO_URI=mongodb://localhost:27017/jet_express

# =========================
# 💳 PAYMENT PROVIDERS
# =========================

# Wave Money
WAVE_API_KEY=your_wave_api_key
WAVE_API_SECRET=your_wave_secret
WAVE_BASE_URL=https://api.wave.com

# Orange Money
ORANGE_API_KEY=your_orange_api_key
ORANGE_API_SECRET=your_orange_secret
ORANGE_BASE_URL=https://api.orange.com

# MTN Mobile Money
MTN_API_KEY=your_mtn_api_key
MTN_API_SECRET=your_mtn_secret

# Moov Money
MOOV_API_KEY=your_moov_api_key
MOOV_API_SECRET=your_moov_secret

# =========================
# 📲 NOTIFICATIONS
# =========================

# SMS Gateway
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=JETEXPRESS

# Email Service (Brevo / Sendgrid / etc.)
EMAIL_API_KEY=your_email_api_key
EMAIL_FROM=no-reply@jetexpress.com

# =========================
# 🎟️ QR CODE / TICKET SYSTEM
# =========================
QR_SECRET_KEY=your_qr_secret_key

# =========================
# 🔔 WEBHOOK SECURITY
# =========================
PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# =========================
# ⚙️ SYSTEM CONFIG DEFAULTS
# =========================
DEFAULT_CURRENCY=XOF
DEFAULT_TIMEZONE=UTC

# =========================
# 📊 LOGGING / MONITORING
# =========================
LOG_LEVEL=info

# =========================
# 🌐 CORS
# =========================
CORS_ORIGIN=http://localhost:3000

# =========================
# ☁️ OPTIONAL (PRODUCTION)
# =========================
# REDIS_URL=redis://localhost:6379
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY=
# AWS_SECRET_KEY=